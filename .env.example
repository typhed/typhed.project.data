# --------------------------------------------------------------------
# Clerk Webhook & Database Endpoint - Environment Configuration
#
# Copy this file to ".env" and the real values will be used in testing
# the application in localhost. In production system, recommended to
# configure from the path variables (see src/app/core/config.py).
# --------------------------------------------------------------------

# Asynchronous PostgreSQL DSN: The "+asyncpg" driver suffix is mandatory -
# a plain (w/o asychronous operations) will block the event loop.
DATABASE_URL = postgresql+asyncpg://username:password@localhost:5432/database

# Clerk Webhook Signing Secret: Clerk Dashboard → API Keys → Secret Key
# The value always starts with "whsec_" prefix, keep it confidential.
CLERK_WEBHOOK_SIGNING_SECRET = whsec_
